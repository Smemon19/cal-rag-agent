# Vector storage backend
VECTOR_BACKEND=bigquery

# BigQuery configuration
BQ_PROJECT=badgers-487618
BQ_DATASET=cal_rag
BQ_TABLE=documents

# Embedding backend: "vertex" (default), "sentence", or "openai"
EMBEDDING_BACKEND=vertex
VERTEX_PROJECT_ID=badgers-487618
VERTEX_LOCATION=us-east1
VERTEX_EMBEDDING_MODEL=text-embedding-005

# LLM model (Vertex AI Gemini)
CAL_MODEL_NAME=gemini-1.5-pro

# RAG collection name
RAG_COLLECTION_NAME=default

# (Optional) Google Application Default Credentials
# On Cloud Run: ADC is automatic via the attached service account.
# Locally: run `gcloud auth application-default login`
# Only set this if you need a specific service account key file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# (Optional) OpenAI - only needed if EMBEDDING_BACKEND=openai or using GPT models
# OPENAI_API_KEY=
# OPENAI_EMBED_MODEL=text-embedding-3-large
